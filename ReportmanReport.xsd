    </xs:annotation>
    <xs:sequence>
      <xs:element name="NAME" type="PropertyElement" minOccurs="1"/>
      <xs:choice minOccurs="0" maxOccurs="unbounded">
        <xs:element name="ALIAS" type="PropertyElement"/>
        <xs:element name="PARENTSUBREPORT" type="PropertyElement">
          <xs:annotation><xs:documentation>Parent subreport name reference (String)</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="PARENTSECTION" type="PropertyElement">
          <xs:annotation><xs:documentation>Parent section name reference (String)</xs:documentation></xs:annotation>
        </xs:element>
        <xs:element name="PRINTONLYIFDATAAVAILABLE" type="PropertyElement"/>
        <xs:element name="REOPENONPRINT" type="PropertyElement"/>
        <xs:element name="SECTION" type="SectionType_Element"/>
      </xs:choice>
    </xs:sequence>
  </xs:complexType>

